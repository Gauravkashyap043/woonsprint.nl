---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import { mainNavigation } from '../data/navigation';
import { footerColumns } from '../data/footer';
import { getCollection } from 'astro:content';
import { getBlogPostUrl } from '../utils/blog';

const blogPosts = (await getCollection('blog')).sort(
  (a, b) => a.data.title.localeCompare(b.data.title, 'nl'),
);

const staticPages = [
  { label: 'Home', href: '/' },
  { label: 'Contact', href: '/contact/' },
  { label: 'Over ons', href: '/over-ons/' },
  { label: 'Blogoverzicht', href: '/blogoverzicht/' },
  { label: 'Gereedschappen', href: '/gereedschappen/' },
  { label: 'Inrichting', href: '/inrichting/' },
  { label: 'Slaapkamer', href: '/slaapkamer/' },
];

const navLinks = mainNavigation.flatMap((item) => [
  { label: item.label, href: item.href },
  ...(item.children ?? []),
]);

const footerLinks = footerColumns.flatMap((col) => col.links);
const allLinks = [...staticPages, ...navLinks, ...footerLinks];
const uniqueLinks = Array.from(new Map(allLinks.map((l) => [l.href, l])).values()).sort((a, b) =>
  a.label.localeCompare(b.label, 'nl'),
);
---

<BaseLayout title="Sitemap | Woonsprint.nl" description="Overzicht van alle pagina's op Woonsprint.nl.">
  <Hero title="Sitemap" subtitle="Overzicht van alle pagina's op Woonsprint.nl" compact={true} />
  <section class="section">
    <div class="container">
      <h2>Pagina's</h2>
      <ul class="sitemap-list">
        {uniqueLinks.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>

      <h2>Blogs</h2>
      <ul class="sitemap-list">
        {blogPosts.map((post) => (
          <li><a href={getBlogPostUrl(post.id)}>{post.data.title}</a></li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  h2 {
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .sitemap-list {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem 1.5rem;
    margin-bottom: 2rem;
  }

  .sitemap-list a {
    font-size: 0.9375rem;
    color: var(--color-text);
  }

  .sitemap-list a:hover {
    color: var(--color-accent);
  }

  @media (max-width: 767px) {
    .sitemap-list {
      grid-template-columns: 1fr;
    }
  }
</style>
