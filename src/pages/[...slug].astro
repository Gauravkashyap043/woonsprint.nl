---
import { getCollection, render } from 'astro:content';
import BlogPostLayout from '../layouts/BlogPostLayout.astro';
import ProductPageLayout from '../layouts/ProductPageLayout.astro';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  const productEntries = await getCollection('products');

  const blogPaths = blogEntries.map((entry) => ({
    params: { slug: entry.id },
    props: { type: 'blog' as const, entry },
  }));

  const productPaths = productEntries.map((entry) => ({
    params: { slug: entry.id },
    props: { type: 'product' as const, entry },
  }));

  return [...blogPaths, ...productPaths];
}

const { type, entry } = Astro.props;

let Content;
if (entry && type === 'blog') {
  ({ Content } = await render(entry));
}

function splitProductBody(body: string) {
  const introMatch = body.match(/<div class="product-hero-intro">[\s\S]*?<\/div>/);
  const introHtml = introMatch?.[0] ?? '';
  const bodyHtml = body.replace(introHtml, '').trim();
  return { introHtml, bodyHtml };
}

const productParts = entry && type === 'product' ? splitProductBody(entry.body) : null;
---

{
  type === 'blog' ? (
    <BlogPostLayout entry={entry!}>
      <Content />
    </BlogPostLayout>
  ) : (
    <ProductPageLayout
      entry={entry!}
      introHtml={productParts!.introHtml}
      bodyHtml={productParts!.bodyHtml}
    />
  )
}
