---
interface Props {
  name?: string;
  role?: string;
  bio?: string;
  image?: string;
}

const {
  name = 'Tristan',
  role = 'Blogger',
  bio = 'Als voormalig interieurdesigner, deel ik graag mijn kennis met het team van WoonblogMagazine. Voorheen schreef ik ook voor sites als woonvoordelig, om mensen tips te geven over voordelig wonen! Tijdens mijn carrière heb ik gezien dat Nederland zo veel creatieve mensen heeft in het inrichten van hun huis. Soms heb je gewoon een steuntje in de rug nodig. Op deze site kun je inspiratie opdoen of te weten komen welke producten die jij voor ogen hebt voor je huis de moeite waard zijn om te kopen.',
  image = '/images/brand/tristan.png',
} = Astro.props;

const socials = [
  { label: 'Facebook', href: '#', icon: 'M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z' },
  { label: 'Twitter', href: '#', icon: 'M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z' },
  { label: 'Instagram', href: '#', icon: 'M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z M17.5 6.5h.01' },
  { label: 'LinkedIn', href: '#', icon: 'M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-4 0v7h-4v-7a6 6 0 016-6z M2 9h4v12H2z M4 6a2 2 0 100-4 2 2 0 000 4z' },
];
---

<section class="testimonial divider-section">
  <div class="container testimonial__grid">
    <div class="testimonial__image">
      <img src={image} alt={`${name}, ${role}`} width="375" height="458" loading="lazy" />
    </div>
    <div class="testimonial__content">
      <h4>{name}</h4>
      <p class="testimonial__role">{role}</p>
      <p class="testimonial__bio">{bio}</p>
      <div class="testimonial__social" role="list">
        {
          socials.map((social) => (
            <a href={social.href} class="testimonial__social-link" aria-label={social.label} role="listitem">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d={social.icon} />
              </svg>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .testimonial__grid {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 3rem;
    align-items: center;
  }

  .testimonial__image img {
    width: 100%;
    max-width: 375px;
    border-radius: var(--radius-md);
  }

  .testimonial__role {
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  .testimonial__bio {
    color: var(--color-text-muted);
    line-height: 1.65;
    margin-bottom: 1.5rem;
  }

  .testimonial__social {
    display: flex;
    gap: 0.75rem;
  }

  .testimonial__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    color: var(--color-accent);
    background: var(--color-white);
    border-radius: var(--radius-sm);
    transition:
      transform var(--transition),
      color var(--transition);
  }

  .testimonial__social-link:hover {
    color: #b8915f;
    transform: translateY(-2px);
  }

  @media (max-width: 767px) {
    .testimonial__grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .testimonial__image {
      text-align: center;
    }

    .testimonial__image img {
      margin-inline: auto;
    }
  }
</style>
