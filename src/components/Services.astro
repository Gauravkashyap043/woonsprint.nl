---
import { homepageCategories } from '../data/homepage';
---

<section class="section categories" id="categorieen">
  <div class="container">
    <div class="section-title section-title--left">
      <h3>Categorieën</h3>
      <p>Klik hieronder door op de categorie van jouw keuze</p>
    </div>

    <div class="categories__grid">
      {
        homepageCategories.map((category) => (
          <a href={category.href} class="categories__card card">
            <span class="categories__icon" aria-hidden="true">
              <img src={category.icon} alt="" width="48" height="48" loading="lazy" />
            </span>
            <h4 class="categories__title">{category.title}</h4>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .section-title--left,
  .section-title--left h3,
  .section-title--left p {
    text-align: left;
  }

  .categories {
    background: rgba(39, 64, 97, 0.1);
    padding-bottom: 7.75rem;
  }

  .categories__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  .categories__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 1.5rem 1rem;
    color: inherit;
    margin: 0.625rem;
  }

  .categories__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.75rem;
  }

  .categories__icon img {
    width: 48px;
    height: 48px;
  }

  .categories__title {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 500;
    margin: 0;
    transition: color var(--transition);
  }

  .categories__card:hover .categories__title {
    color: var(--color-navy);
  }

  @media (max-width: 1023px) {
    .categories__grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .categories {
      padding-bottom: 4.5rem;
    }
  }

  @media (max-width: 767px) {
    .categories__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.75rem;
    }

    .categories__card {
      margin: 0;
      padding: 1.25rem 0.75rem;
    }

    .categories {
      padding-bottom: 2.25rem;
    }
  }
</style>
