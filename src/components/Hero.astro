---
import { heroParagraphs } from '../data/homepage';

interface Props {
  title?: string;
  paragraphs?: string[];
  image?: string;
  compact?: boolean;
}

const {
  title = 'Transformeer jouw huis in een thuis!',
  paragraphs = heroParagraphs,
  image = '/wp-content/uploads/2022/11/Frame1.svg',
  compact = false,
} = Astro.props;
---

<section class:list={['hero', { 'hero--compact': compact }]}>
  <div class="container hero__grid">
    <div class="hero__content">
      <h1>{title}</h1>
      {
        paragraphs.length > 0 && (
          <div class="hero__subtitle">
            {paragraphs.map((paragraph) => (
              <p>{paragraph}</p>
            ))}
          </div>
        )
      }
    </div>
    {!compact && (
      <div class="hero__visual">
        <img src={image} alt="" width="639" height="470" loading="eager" />
      </div>
    )}
  </div>
</section>

<style>
  .hero {
    background: var(--color-navy);
    padding-block: 7.75rem 7.75rem;
    margin-top: 0;
  }

  .hero--compact {
    padding-block: 4.5rem;
  }

  .hero__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: center;
  }

  .hero__content {
    max-width: 560px;
    text-align: left;
  }

  .hero h1 {
    color: var(--color-white);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 500;
    line-height: 1.2;
    margin-bottom: 1.5rem;
    text-align: left;
  }

  .hero__subtitle p {
    color: #fffdfd;
    font-size: clamp(0.9375rem, 2vw, 1rem);
    line-height: 1.65;
    margin: 0 0 1rem;
    text-align: left;
  }

  .hero__subtitle p:last-child {
    margin-bottom: 0;
  }

  .hero__visual {
    display: flex;
    justify-content: flex-end;
    align-items: flex-end;
  }

  .hero__visual img {
    width: 100%;
    max-width: 520px;
  }

  .hero--compact .hero__grid {
    grid-template-columns: 1fr;
  }

  @media (max-width: 1023px) {
    .hero {
      padding-block: 6rem 4.5rem;
    }

    .hero__grid {
      grid-template-columns: 1fr;
    }

    .hero__visual {
      justify-content: center;
    }

    .hero__visual img {
      max-width: 360px;
    }
  }

  @media (max-width: 767px) {
    .hero {
      padding-block: 5.5rem 2.25rem;
    }

    .hero__visual img {
      max-width: 50%;
      margin-inline: auto;
    }
  }
</style>
