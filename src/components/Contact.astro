---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Neem contact op',
  description = 'Heb je een vraag, tip of suggestie? Vul het formulier in en we nemen zo snel mogelijk contact met je op.',
} = Astro.props;
---

<section class="contact">
  <div class="container contact__inner">
    <div class="contact__intro">
      <h2>{title}</h2>
      <p>{description}</p>
    </div>
    <form class="contact__form" action="#" method="post">
      <div class="contact__field">
        <label for="naam">Naam</label>
        <input type="text" id="naam" name="naam" placeholder="Naam" required autocomplete="name" />
      </div>
      <div class="contact__field">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" placeholder="Email" required autocomplete="email" />
      </div>
      <div class="contact__field">
        <label for="bericht">Bericht</label>
        <textarea id="bericht" name="bericht" placeholder="Bericht" rows="6" required></textarea>
      </div>
      <button type="submit" class="btn btn--primary">Versturen</button>
    </form>
  </div>
</section>

<style>
  .contact {
    padding-block: 3rem 4rem;
  }

  .contact__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  .contact__intro h2 {
    margin-bottom: 1rem;
  }

  .contact__intro p {
    color: var(--color-text-muted);
    line-height: 1.65;
  }

  .contact__form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contact__field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .contact__field label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .contact__field input,
  .contact__field textarea {
    width: 100%;
    padding: 0.875rem 1rem;
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-text);
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    transition:
      border-color var(--transition),
      box-shadow var(--transition);
  }

  .contact__field input:focus,
  .contact__field textarea:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(205, 162, 116, 0.2);
  }

  .contact__field textarea {
    resize: vertical;
    min-height: 140px;
  }

  @media (max-width: 767px) {
    .contact__inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
