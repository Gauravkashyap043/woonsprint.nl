---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { siteMeta } from '../data/navigation';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = siteMeta.title,
  description = siteMeta.description,
  ogImage = '/wp-content/uploads/2022/11/Frame1.svg',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, siteMeta.url);
---

<!doctype html>
<html lang="nl-NL">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/wp-content/uploads/2022/11/cropped-Group-11-32x32.png" />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={new URL(ogImage, siteMeta.url)} />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#content">Ga naar de inhoud</a>
    <Header />
    <main id="content">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  main {
    min-height: 50vh;
  }
</style>
