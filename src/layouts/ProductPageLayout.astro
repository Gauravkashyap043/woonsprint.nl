---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';

interface Props {
  entry: CollectionEntry<'products'>;
}

const { entry } = Astro.props;
const {
  title,
  heading,
  description,
  updatedDate,
  updatedLabel,
  breadcrumbParent,
  breadcrumbParentHref,
  breadcrumbLabel,
} = entry.data;

const months = ['jan.', 'feb.', 'mrt.', 'apr.', 'mei', 'jun.', 'jul.', 'aug.', 'sep.', 'okt.', 'nov.', 'dec.'];
const formattedUpdated =
  updatedLabel ||
  `Laatst bijgewerkt: ${entry.data.updatedDate.getDate()} ${months[entry.data.updatedDate.getMonth()]} ${entry.data.updatedDate.getFullYear()}`;
---

<BaseLayout title={title} description={description} ogImage="/images/brand/hero-bg.png">
  <article class="product-detail">
    <section class="product-detail__hero">
      <div class="product-detail__hero-overlay"></div>
      <div class="container product-detail__hero-inner">
        <nav class="product-detail__breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span aria-hidden="true"> » </span>
          <a href={breadcrumbParentHref}>{breadcrumbParent}</a>
          <span aria-hidden="true"> » </span>
          <span>{breadcrumbLabel}</span>
        </nav>
        <h1>{heading}</h1>
        <p class="product-detail__updated">{formattedUpdated}</p>
      </div>
    </section>

    <div class="container product-detail__content">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .product-detail__hero {
    position: relative;
    background: var(--color-navy);
    background-image: url('/images/brand/hero-bg.png');
    background-size: cover;
    background-position: center;
    color: var(--color-white);
    padding: 7rem 0 4rem;
  }

  .product-detail__hero-overlay {
    position: absolute;
    inset: 0;
    background: var(--color-navy-overlay);
  }

  .product-detail__hero-inner {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 820px;
  }

  .product-detail__breadcrumb {
    font-size: 0.875rem;
    margin-bottom: 1.5rem;
    color: rgba(255, 255, 255, 0.85);
  }

  .product-detail__breadcrumb a {
    color: rgba(255, 255, 255, 0.85);
  }

  .product-detail__breadcrumb a:hover {
    color: var(--color-accent);
  }

  .product-detail__hero h1 {
    color: var(--color-white);
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    margin-bottom: 1rem;
  }

  .product-detail__updated {
    font-size: 0.9375rem;
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: 2rem;
  }

  .product-detail__content {
    padding-block: 3rem 4rem;
  }

  .product-detail__content :global(.product-hero-intro) {
    text-align: center;
    max-width: 820px;
    margin: 0 auto 3rem;
  }

  .product-detail__content :global(.product-hero-intro p) {
    line-height: 1.65;
    margin-bottom: 1rem;
    color: var(--color-text);
  }

  .product-detail__content :global(.product-hero-intro .elementor-button) {
    display: inline-block;
    margin-top: 1rem;
    padding: 0.875rem 1.75rem;
    background: var(--color-accent);
    color: var(--color-white);
    border-radius: var(--radius-sm);
    font-weight: 600;
    text-decoration: none;
  }

  .product-detail__content :global(.product-hero-intro .elementor-button:hover) {
    background: #b8915f;
    color: var(--color-white);
  }

  .product-detail__content :global(.product-body h2) {
    font-size: 1.75rem;
    margin-bottom: 1.5rem;
  }

  .product-detail__content :global(.product-body h3) {
    font-size: 1.125rem;
    font-weight: 600;
    margin: 0 0 0.75rem;
    line-height: 1.4;
  }

  .product-detail__content :global(.product-body .elementor-section) {
    margin-bottom: 0;
  }

  .product-detail__content :global(.product-body .elementor-column-wrap) {
    padding: 0.5rem;
  }

  .product-detail__content :global(.product-body .elementor-container) {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-bottom: 1rem;
  }

  .product-detail__content :global(.product-body .elementor-col-66) {
    flex: 1 1 calc(66% - 1rem);
    min-width: 280px;
  }

  .product-detail__content :global(.product-body .elementor-col-33) {
    flex: 1 1 calc(33% - 1rem);
    min-width: 220px;
  }

  .product-detail__content :global(.product-body .elementor-col-50) {
    flex: 1 1 calc(50% - 1rem);
    min-width: 260px;
  }

  .product-detail__content :global(.product-body .elementor-inner-section .elementor-container) {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  .product-detail__content :global(.product-body .elementor-row) {
    display: contents;
  }

  .product-detail__content :global(.product-body img) {
    max-width: 400px;
    height: auto;
    float: left;
    margin: 0 1.25rem 1rem 0;
    border-radius: var(--radius-sm);
  }

  .product-detail__content :global(.product-body p) {
    line-height: 1.65;
    margin-bottom: 1rem;
    color: var(--color-text);
  }

  .product-detail__content :global(.product-body a) {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .product-detail__content :global(.product-body .elementor-button) {
    display: inline-block;
    margin-top: 0.5rem;
    padding: 0.625rem 1.25rem;
    background: var(--color-accent);
    color: var(--color-white) !important;
    border-radius: var(--radius-sm);
    font-weight: 600;
    text-decoration: none !important;
  }

  @media (max-width: 1023px) {
    .product-detail__content :global(.product-body .elementor-row) {
      grid-template-columns: 1fr;
    }

    .product-detail__content :global(.product-body img) {
      float: none;
      margin: 0 auto 1rem;
      display: block;
    }
  }
</style>
