---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import '../styles/product-elementor.css';

interface Props {
  entry: CollectionEntry<'products'>;
  introHtml: string;
  bodyHtml: string;
}

const { entry, introHtml, bodyHtml } = Astro.props;
const {
  title,
  heading,
  description,
  updatedLabel,
  breadcrumbParent,
  breadcrumbParentHref,
  breadcrumbLabel,
} = entry.data;

const months = ['jan.', 'feb.', 'mrt.', 'apr.', 'mei', 'jun.', 'jul.', 'aug.', 'sep.', 'okt.', 'nov.', 'dec.'];
const formattedUpdated =
  updatedLabel ||
  `Laatst bijgewerkt: ${entry.data.updatedDate.getDate()} ${months[entry.data.updatedDate.getMonth()]} ${entry.data.updatedDate.getFullYear()}`;
---

<BaseLayout title={title} description={description} ogImage="/wp-content/uploads/2022/11/Frame1.svg">
  <article class="product-detail">
    <section class="product-detail__top">
      <div class="container product-detail__top-grid">
        <div class="product-detail__top-main">
          <nav class="product-detail__breadcrumb" aria-label="Breadcrumb">
            <a href="/">Home</a>
            <span aria-hidden="true"> » </span>
            <a href={breadcrumbParentHref}>{breadcrumbParent}</a>
            <span aria-hidden="true"> » </span>
            <span>{breadcrumbLabel}</span>
          </nav>
          <h1>{heading}</h1>
          <p class="product-detail__updated">{formattedUpdated}</p>
          {introHtml && <Fragment set:html={introHtml} />}
        </div>
        <div class="product-detail__top-visual" aria-hidden="true">
          <img
            src="/wp-content/uploads/2022/11/Frame1.svg"
            alt=""
            width="639"
            height="470"
            loading="eager"
          />
        </div>
      </div>
    </section>

    <section class="product-detail__main">
      <div class="container">
        <Fragment set:html={bodyHtml} />
      </div>
    </section>
  </article>
</BaseLayout>

<script>
  document.querySelectorAll('.elementor-accordion-item').forEach((item) => {
    const title = item.querySelector('.elementor-tab-title');
    const content = item.querySelector('.elementor-tab-content');
    if (!title || !content) return;

    content.classList.remove('elementor-active');
    title.setAttribute('aria-expanded', 'false');

    title.addEventListener('click', () => {
      const isOpen = title.getAttribute('aria-expanded') === 'true';
      title.setAttribute('aria-expanded', String(!isOpen));
      content.classList.toggle('elementor-active', !isOpen);
    });
  });
</script>

<style>
  .product-detail__top {
    background: var(--color-navy);
    padding: 5rem 0 3rem;
  }

  .product-detail__top-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 2rem;
    align-items: start;
  }

  .product-detail__top-main {
    max-width: 560px;
    text-align: left;
  }

  .product-detail__top-visual {
    display: flex;
    justify-content: flex-end;
    align-items: flex-start;
    padding-top: 2rem;
  }

  .product-detail__top-visual img {
    max-width: min(100%, 520px);
    height: auto;
  }

  .product-detail__breadcrumb {
    font-family: var(--font-heading);
    font-size: 0.875rem;
    margin-bottom: 1.25rem;
    color: rgba(255, 255, 255, 0.85);
  }

  .product-detail__breadcrumb a {
    color: rgba(255, 255, 255, 0.85);
  }

  .product-detail__breadcrumb a:hover {
    color: var(--color-accent);
  }

  .product-detail__top-main h1 {
    color: var(--color-white);
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 500;
    line-height: 1.2;
    margin-bottom: 1rem;
    text-align: left;
  }

  .product-detail__updated {
    font-family: var(--font-heading);
    font-size: 0.9375rem;
    color: rgba(255, 255, 255, 0.9);
    margin: 0 0 1.5rem;
  }

  .product-detail__top-main :global(.product-hero-intro) {
    color: var(--color-white);
  }

  .product-detail__top-main :global(.product-hero-intro p) {
    color: rgba(255, 255, 255, 0.95);
    line-height: 1.65;
    margin-bottom: 1rem;
    font-size: 1rem;
  }

  .product-detail__main {
    background: var(--color-white);
    color: var(--color-text);
    padding: 3rem 0 0;
  }

  .product-detail__main :global(.product-body),
  .product-detail__main :global(.product-body p),
  .product-detail__main :global(.product-body h2),
  .product-detail__main :global(.product-body h3) {
    color: var(--color-text);
  }

  .product-detail__main :global(.product-body a:not(.elementor-button)) {
    color: var(--color-accent);
    text-decoration: underline;
  }

  @media (max-width: 1023px) {
    .product-detail__top {
      padding-top: 4rem;
    }

    .product-detail__top-grid {
      grid-template-columns: 1fr;
    }

    .product-detail__top-visual {
      order: -1;
      justify-content: center;
      padding-top: 0;
      margin-bottom: 1rem;
    }

    .product-detail__top-visual img {
      max-width: 260px;
    }

    .product-detail__top-main {
      max-width: 100%;
    }
  }
</style>
